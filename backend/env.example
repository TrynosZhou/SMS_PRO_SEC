# Server Configuration
PORT=3000
# Set to true to skip aligning stored student numbers with Settings student ID prefix on startup
# SKIP_STUDENT_ID_PREFIX_SYNC=false
# Set to true to skip aligning stored teacher IDs with Settings teacher ID prefix on startup
# SKIP_TEACHER_ID_PREFIX_SYNC=false

# Database Configuration
# Production (Render, etc.): set DATABASE_URL from the dashboard Internal/External Database URL.
# Example: postgres://user:pass@dpg-xxxxx.region-postgres.render.com/dbname
# DATABASE_URL=

# Local dev without DATABASE_URL:
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=sms_db
# Hosted Postgres: SSL is auto-enabled when DATABASE_URL or DB_HOST matches render.com (etc.).
# Force on: DB_SSL=true   Force off: DB_SSL=false

# JWT Configuration (REQUIRED - Server will not start without JWT_SECRET)
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Minimum 32 characters recommended for security
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_characters
JWT_EXPIRES_IN=7d

# Production CORS: browser Origin must match (scheme + host; trailing slash is normalized).
# Custom domains (not *.vercel.app) must be listed via FRONTEND_URL or CORS_ORIGINS.
# FRONTEND_URL=https://your-app.vercel.app
# CORS_ORIGINS=https://www.example.com,https://app.example.com

# Docker Configuration (if using Docker for backend)
# DB_HOST=postgres
# DB_PORT=5432

# OpenAI Configuration (for AI-generated remarks)
OPENAI_API_KEY=your_openai_api_key_here
# Optional; default is gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini

# Payment Gateway Configuration
# EcoCash
ECOCASH_MERCHANT_CODE=your_ecocash_merchant_code
ECOCASH_API_KEY=your_ecocash_api_key

# InnBucks
INNBUCKS_MERCHANT_ID=your_innbucks_merchant_id
INNBUCKS_API_KEY=your_innbucks_api_key

# Visa/Mastercard (use Stripe, PayPal, or local processor)
VISA_MERCHANT_ID=your_visa_merchant_id
VISA_API_KEY=your_visa_api_key
VISA_SECRET_KEY=your_visa_secret_key

